<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SecretList.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    XYFocusKeyboardNavigation="Disabled"
    KeyDown="Page_KeyDown">

    <Page.Resources>
        <!-- Field row: label + a normal one-line TextBox. Every tag uses
             this same template now - if you need more room than one line
             (e.g. a multi-part address), add separate tags for it
             (AddressL1/AddressL2, Notes/Notes1, etc.) rather than relying
             on a multi-line field. -->
        <DataTemplate x:Key="FieldRowTemplate">
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding TagName}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Value, Mode=TwoWay}"
                         IsReadOnly="{Binding IsReadOnly}"
                         IsTabStop="{Binding IsTabStop}"/>
            </Grid>
        </DataTemplate>

        <!-- Schema status colors, now shown on the "..." menu button:
             green = schema.md is in place and parsed successfully (custom
             or freshly-seeded); red = it's missing/broken and we've
             fallen back to the built-in default. -->
        <SolidColorBrush x:Key="ImportValidBrush" Color="{ThemeResource SystemFillColorSuccess}"/>
        <SolidColorBrush x:Key="ImportInvalidBrush" Color="{ThemeResource SystemFillColorCritical}"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: title on the left, Category nav (First/Prev/Next/Last)
             on the right. This nav is always about "which category am I
             browsing" - it lives near the heading since that's what the
             heading itself reflects, and stays disabled while unlocked/
             editing, same rule as before, just relocated. -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="HeaderText"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Category:" VerticalAlignment="Center"/>
                <Button x:Name="TypeFirstButton" Content="First" Click="TypeFirstButton_Click"/>
                <Button x:Name="TypePrevButton" Content="Prev" Click="TypePrevButton_Click"/>
                <Button x:Name="TypeNextButton" Content="Next" Click="TypeNextButton_Click"/>
                <Button x:Name="TypeLastButton" Content="Last" Click="TypeLastButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Toolbar area: a contextual Category picker (row 0, collapsed
             unless unlocked) sitting directly above the main action row
             (row 1), sharing the same column layout so it lines up over
             the right-hand action group. -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Category picker: only meaningful while unlocked (editing
                 or mid-Add), so it's collapsed the rest of the time and
                 never takes up space when hidden. Always shows the
                 current record's category when visible - see
                 ShowCurrentRecord in the code-behind. -->
            <StackPanel x:Name="CategoryPickerPanel"
                        Grid.Row="0" Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,6"
                        Visibility="Collapsed">
                <TextBlock Text="Category:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CategoryComboBox"
                          Width="150"
                          SelectionChanged="CategoryComboBox_SelectionChanged"/>
            </StackPanel>

            <!-- Left: Record nav grouped right next to Nickname, since
                 they're both "which record" controls - keeping them
                 together makes that relationship obvious at a glance. -->
            <StackPanel Grid.Row="1" Grid.Column="0"
                        Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="RecordFirstButton" Content="First" Click="RecordFirstButton_Click"/>
                <Button x:Name="RecordPrevButton" Content="Prev" Click="RecordPrevButton_Click"/>
                <Button x:Name="RecordNextButton" Content="Next" Click="RecordNextButton_Click"/>
                <Button x:Name="RecordLastButton" Content="Last" Click="RecordLastButton_Click"/>
                <TextBlock Text="Nickname:" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBox x:Name="NicknameTextBox" Width="220"/>
            </StackPanel>

            <!-- Right: actions, plus a "..." menu holding the less-frequent
                 schema Import/Export commands so they're out of the way. -->
            <StackPanel Grid.Row="1" Grid.Column="2"
                        Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="LockButton"
                        Content="Unlock"
                        Click="LockButton_Click"
                        Style="{StaticResource AccentButtonStyle}"/>
                <Button x:Name="AddButton"
                        Content="Add New"
                        Click="AddButton_Click"/>
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="CancelButton_Click"/>
                <Button x:Name="DeleteButton"
                        Content="Delete"
                        Click="DeleteButton_Click"/>
                <Button x:Name="PrintButton"
                        Content="Print"
                        Click="PrintButton_Click"/>
                <Button x:Name="MoreButton"
                        Content="..."
                        Foreground="White">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem x:Name="ExportSchemaMenuItem"
                                            Text="Export Schema"
                                            Click="ExportSchemaMenuItem_Click"/>
                            <MenuFlyoutItem x:Name="ImportSchemaMenuItem"
                                            Text="Import Schema"
                                            Click="ImportSchemaMenuItem_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Field rows -->
        <ItemsControl Grid.Row="2"
                      x:Name="FieldsControl"
                      ItemTemplate="{StaticResource FieldRowTemplate}"/>

        <!-- Exit, bottom-left - out of the way of the main toolbar so it
             won't be hit accidentally while working. -->
        <Button Grid.Row="3"
                x:Name="ExitButton"
                Content="Exit"
                Click="ExitButton_Click"
                HorizontalAlignment="Left"
                Margin="0,16,0,0"/>

        <!-- Search overlay - hidden until Ctrl+F is pressed -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              x:Name="SearchOverlay"
              Background="{ThemeResource SmokeFillColorDefaultBrush}"
              Visibility="Collapsed">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Width="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="10">
                    <TextBlock Text="Find by Nickname"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBox x:Name="SearchTextBox"
                             PlaceholderText="Type a nickname, Enter to search, Esc to close"
                             KeyDown="SearchTextBox_KeyDown"/>
                    <ListView x:Name="SearchResultsListView"
                              MaxHeight="300"
                              IsItemClickEnabled="True"
                              ItemClick="SearchResultsListView_ItemClick"
                              KeyDown="SearchResultsListView_KeyDown">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayLine}"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
